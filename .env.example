PORT=3000
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Default admin credentials (created on first run)
ADMIN_EMAIL=admin@astroparks.io
ADMIN_PASSWORD=change_me_in_production

# SMTP — use your email provider settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@astroparks.io
SMTP_PASS=your_smtp_app_password

# Public URL of your deployment (used in email links)
APP_URL=http://localhost:3000

# ── PostgreSQL connection ──────────────────────────────────────────────────
#
# Option A — Local PostgreSQL (install from https://www.postgresql.org/download/)
#   After installing, open psql and run:
#     CREATE DATABASE astroparks;
#     CREATE USER astroparks_user WITH PASSWORD 'yourpassword';
#     GRANT ALL PRIVILEGES ON DATABASE astroparks TO astroparks_user;
#     \c astroparks
#     GRANT ALL ON SCHEMA public TO astroparks_user;
#   Then set:
DATABASE_URL=postgresql://astroparks_user:yourpassword@localhost:5432/astroparks
#
# Option B — Free cloud PostgreSQL (no local install needed)
#   • Neon (neon.tech) — serverless Postgres, free tier available
#   • Supabase (supabase.com) — Postgres + extras, free tier available
#   • Railway (railway.app) — one-click Postgres, free trial
#   Copy the connection string from the provider's dashboard and paste here:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
