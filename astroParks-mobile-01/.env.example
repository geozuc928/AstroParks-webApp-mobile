PORT=3000
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Admin account seeded on first run
ADMIN_EMAIL=admin@astroparks.io
ADMIN_PASSWORD=change_me_in_production

# Public URL (used in email verification links)
APP_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────────────────────────
#
# Option A: Local install  →  https://www.postgresql.org/download/
#   After installing, open psql and run:
#     CREATE DATABASE astroparks;
#     CREATE USER astro_user WITH PASSWORD 'yourpassword';
#     GRANT ALL PRIVILEGES ON DATABASE astroparks TO astro_user;
#     \c astroparks
#     GRANT ALL ON SCHEMA public TO astro_user;
#
DATABASE_URL=postgresql://astro_user:yourpassword@localhost:5432/astroparks
#
# Option B: Free cloud Postgres (no local install)
#   Neon    → https://neon.tech       (serverless, generous free tier)
#   Supabase → https://supabase.com   (Postgres + auth + storage)
#   Railway  → https://railway.app    (one-click Postgres)
#   Paste the provider's connection string above.

# ── SMTP (optional — emails are logged to console if not set) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@astroparks.io
SMTP_PASS=your_smtp_app_password
